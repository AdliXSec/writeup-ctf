# -----------------------------------------------------------------------------
# 0xL33XY CTF Platform - Environment Configuration Example
# -----------------------------------------------------------------------------

# Secret key used for Flask session signing (keep this very secret in production)
FLASK_SECRET=your_super_secret_flask_key_here

# Secret key used for JWT token signing (keep this very secret in production)
JWT_SECRET=your_super_secret_jwt_key_here

# Internal or External URL for the Instance Manager API
# If running on same Docker network (ctf-net), use the internal hostname
INSTANCE_MANAGER_URL=http://ctf-instance-manager:9000

# The external IP or hostname where the CTF is hosted (used to display challenge links)
CTF_HOST=localhost
