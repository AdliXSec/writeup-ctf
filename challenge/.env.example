# -----------------------------------------------------------------------------
# 0xL33XY CTF Instance Manager - Environment Configuration Example
# -----------------------------------------------------------------------------

# The base port to start allocating instances from
PORT_BASE=10000

# The block size for port allocation (number of challenges)
PORT_BLOCK=100

# Maximum number of teams supported
MAX_TEAMS=100

# The Docker network where challenge instances will be attached
# IMPORTANT: This must match the name of the external network in docker-compose
NETWORK_NAME=ctf-net

# Maximum number of instances a single team can run concurrently
MAX_CONCURRENT_INSTANCES=3
